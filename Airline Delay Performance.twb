      <column caption='Aircraft Type' datatype='string' name='[Aircraft_Type]' role='dimension' type='nominal' />
      <column datatype='string' name='[Airline]' role='dimension' type='nominal' />
      <column caption='Arrival Delay Min' datatype='integer' name='[Arrival_Delay_Min]' role='measure' type='quantitative' />
      <column caption='CO2 Emissions kg' datatype='real' name='[CO2_Emissions_kg]' role='measure' type='quantitative' />
      <column caption='Delay Flights' datatype='integer' name='[Calculation_0998665154076672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Arrival_Delay_Min] &gt; 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='% Delayed Flights' datatype='real' default-format='p0%' name='[Calculation_0998665156554753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0998665154076672]) / COUNT([Flight_Number])' />
      </column>
      <column caption='On Time Flights ' datatype='integer' name='[Calculation_0998665158647810]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Arrival_Delay_Min] &lt;= 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_0998665174188035]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='cancelled Flights' datatype='integer' name='[Calculation_0998665178689541]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Cancelled] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Diverted Flights' datatype='integer' name='[Calculation_0998665180168198]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Diverted] = &quot;No&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='cancelled % calculated Fields' datatype='real' name='[Calculation_0998665181831175]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0998665178689541]) / COUNT([Flight_Number])' />
      </column>
      <column caption='Diverted % calculated FIelds' datatype='real' name='[Calculation_0998665182162952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0998665180168198])/COUNT([Flight_Number])' />
      </column>
      <column caption='Calculation2' datatype='real' name='[Calculation_1382124099170304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Departure_Delay_Min])' />
      </column>
